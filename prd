        registry.register("model_router", ModelRouterFilterFactory);
        
        // Observability filters
        registry.register("request_logger", RequestLoggerFilterFactory);
        registry.register("metrics", MetricsFilterFactory);
        
        registry
    }
    
    pub fn create(
        &self, 
        name: &str, 
        config: &Value,
    ) -> Result<Arc<dyn Filter>, FilterError> {
        self.filters
            .get(name)
            .ok_or(FilterError::UnknownFilter(name.to_string()))?
            .create(config)
    }
    
    pub fn schemas(&self) -> HashMap<&str, &str> {
        self.filters
            .iter()
            .map(|(name, factory)| (name.as_str(), factory.config_schema()))
            .collect()
    }
}

pub trait FilterFactory: Send + Sync {
    fn create(&self, config: &Value) -> Result<Arc<dyn Filter>, FilterError>;
    fn config_schema(&self) -> &'static str;
}
