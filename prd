#[async_trait]
impl Filter for RateLimitFilter {
    fn name(&self) -> &'static str { "rate_limit" }
    
    fn supported_phases(&self) -> &[FilterPhase] {
        &[FilterPhase::PreRoute, FilterPhase::PreBackend]
    }
    
    async fn on_request(
        &self,
        ctx: &mut FilterContext,
        _phase: FilterPhase,
    ) -> FilterResult {
        for rule in &self.config.limits {
            // Build rate limit key
            let key = self.build_key(rule, ctx);
            
            // Determine cost (1 for requests, estimated tokens for token limits)
            let cost = match rule.key_type {
                RateLimitKey::Request => 1,
                RateLimitKey::Token => ctx.tokens.input_estimated.unwrap_or(0) as u64,
                RateLimitKey::Byte => ctx.request.body().len() as u64,
            };
            
            // Check rate limit
            let result = ctx.state_store
                .rate_limit_check(&key, rule.limit, rule.window, cost)
                .await
                .map_err(|e| FilterResult::Error {
                    code: 500,
                    message: format!("Rate limit check failed: {}", e),
                    retryable: true,
                })?;
            
            // Store result in context
            ctx.rate_limit.limits_checked.push(result.clone());
            
            if !result.allowed {
                ctx.rate_limit.should_throttle = true;
                ctx.rate_limit.retry_after = result.retry_after;
                
                return FilterResult::Terminate(Response::builder()
                    .status(429)
                    .header("Retry-After", result.retry_after.unwrap().as_secs())
                    .header("X-RateLimit-Limit", rule.limit)
                    .header("X-RateLimit-Remaining", 0)
                    .body(json!({
                        "error": {
                            "code": "RATE_LIMIT_EXCEEDED",
                            "message": format!("Rate limit '{}' exceeded", rule.name),
                            "retry_after": result.retry_after.unwrap().as_secs()
                        }
                    }))
                    .build());
            }
        }
        
        FilterResult::Continue
    }
    
