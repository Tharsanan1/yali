### 7.4. Filter Pipeline Execution

```rust
pub struct FilterPipeline {
    global_filters: Vec<FilterInstance>,
    state_store: Arc<dyn StateStore>,
}

pub struct FilterInstance {
    filter: Arc<dyn Filter>,
    phase: FilterPhase,
    condition: Option<Condition>,
    on_error: OnErrorBehavior,
    timeout: Duration,
}

impl FilterPipeline {
    pub async fn execute_request(
        &self,
        ctx: &mut FilterContext,
        route_filters: &[FilterInstance],
    ) -> Result<(), FilterResult> {
        // PRE_ROUTE phase (global only - route not yet matched)
        self.execute_phase(ctx, FilterPhase::PreRoute, &self.global_filters, &[]).await?;
        
        // Route matching happens here (outside pipeline)
        
        // PRE_BACKEND phase
        self.execute_phase(ctx, FilterPhase::PreBackend, &self.global_filters, route_filters).await?;
        
        // POST_ADAPTER phase (after adapter transforms)
        self.execute_phase(ctx, FilterPhase::PostAdapter, &self.global_filters, route_filters).await?;
        
        Ok(())
    }
    
    pub async fn execute_response(
        &self,
        ctx: &mut FilterContext,
        route_filters: &[FilterInstance],
    ) -> Result<(), FilterResult> {
        // PRE_ADAPTER phase (before adapter normalizes)
        self.execute_phase(ctx, FilterPhase::PreAdapter, &self.global_filters, route_filters).await?;
        
        // POST_BACKEND phase
        self.execute_phase(ctx, FilterPhase::PostBackend, &self.global_filters, route_filters).await?;
        
        // POST_ROUTE phase
        self.execute_phase(ctx, FilterPhase::PostRoute, &self.global_filters, route_filters).await?;
        
        Ok(())
    }
    
    async fn execute_phase(
        &self,
        ctx: &mut FilterContext,
        phase: FilterPhase,
        global: &[FilterInstance],
        route: &[FilterInstance],
    ) -> Result<(), FilterResult> {
        // Global filters first, then route filters
        let filters: Vec<_> = global.iter()
            .chain(route.iter())
            .filter(|f| f.phase == phase)
            .collect();
        
        for instance in filters {
            // Check condition
            if let Some(cond) = &instance.condition {
                if !cond.evaluate(ctx) {
                    continue;
                }
            }
            
            // Execute with timeout
            let result = tokio::time::timeout(
                instance.timeout,
                if phase.is_request_phase() {
                    instance.filter.on_request(ctx, phase)
                } else {
                    instance.filter.on_response(ctx, phase)
                }
            ).await;
            
            match result {
                Ok(FilterResult::Continue) => continue,
                Ok(FilterResult::SkipPhase) => break,
                Ok(FilterResult::Terminate(response)) => {
                    return Err(FilterResult::Terminate(response));
                }
                Ok(FilterResult::Error { code, message, retryable }) => {
                    match instance.on_error {
                        OnErrorBehavior::Terminate => {
                            return Err(FilterResult::Error { code, message, retryable });
                        }
                        OnErrorBehavior::LogAndContinue => {
                            tracing::warn!(filter = instance.filter.name(), %message, "Filter error, continuing");
                            continue;
                        }
                        OnErrorBehavior::Skip => continue,
                    }
                }
                Err(_timeout) => {
                    tracing::warn!(filter = instance.filter.name(), "Filter timeout");
                    match instance.on_error {
                        OnErrorBehavior::Terminate => {
                            return Err(FilterResult::Error {
                                code: 504,
                                message: "Filter timeout".to_string(),
                                retryable: true,
                            });
                        }
                        _ => continue,
                    }
                }
            }
        }
        
        Ok(())
    }
}
